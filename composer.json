{
    "name": "yourproject/php-postgres-app",
    "description": "PHP Application with PostgreSQL and PHPMailer",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "phpmailer/phpmailer": "^6.8",
        "ext-pdo": "*",
        "ext-pgsql": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "App\\\\": "src/"
        }
    }
}
